{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": null,
  "installCommand": null,
  "outputDirectory": ".",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=()"
        }
      ]
    },
    {
      "source": "/(.*\\.html)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/loprado",
      "destination": "/lo-prado",
      "permanent": true
    },
    {
      "source": "/elbosque",
      "destination": "/el-bosque",
      "permanent": true
    },
    {
      "source": "/puentealto",
      "destination": "/puente-alto",
      "permanent": true
    },
    {
      "source": "/quintanormal",
      "destination": "/quinta-normal",
      "permanent": true
    },
    {
      "source": "/qn",
      "destination": "/quinta-normal",
      "permanent": true
    },
    {
      "source": "/tal",
      "destination": "/talagante",
      "permanent": true
    },
    {
      "source": "/peñalolen",
      "destination": "/penalolen",
      "permanent": true
    },
    {
      "source": "/peñalolén",
      "destination": "/penalolen",
      "permanent": true
    },
    {
      "source": "/penalolén",
      "destination": "/penalolen",
      "permanent": true
    },
    {
      "source": "/pen",
      "destination": "/penalolen",
      "permanent": true
    },
    {
      "source": "/loespejo",
      "destination": "/lo-espejo",
      "permanent": true
    },
    {
      "source": "/mel",
      "destination": "/melipilla",
      "permanent": true
    },
    {
      "source": "/biobio/concepción",
      "destination": "/biobio/concepcion",
      "permanent": true
    },
    {
      "source": "/biobio/los-angeles",
      "destination": "/biobio/los-angeles",
      "permanent": false
    },
    {
      "source": "/biobío",
      "destination": "/biobio",
      "permanent": true
    }
  ]
}